    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.9",
    "@types/uuid": "^10.0.0",
    "rimraf": "^5.0.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  }
