# ============================================================
# Government Exam Execution Platform — Environment Variables
# ============================================================

# Server
NODE_ENV=development
PORT=8080
API_VERSION=v1

# PostgreSQL — update with your actual credentials
DATABASE_URL="postgresql://postgres:password@localhost:5432/exam_suchana?schema=public"

# Redis — for caching and BullMQ queues
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Cache TTL (seconds)
CACHE_TTL_EXAM_LIST=300     # 5 minutes
CACHE_TTL_EXAM_DETAIL=600   # 10 minutes
CACHE_TTL_TIMELINE=300      # 5 minutes

# Firebase Cloud Messaging (FCM)
# Get this from Firebase Console > Project Settings > Service Accounts
