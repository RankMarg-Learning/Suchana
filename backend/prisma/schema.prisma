generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ScrapeSource {
  id            String      @id @default(cuid())
  url           String      @unique
  label         String
  sourceType    String      @default("LISTING")
  hintCategory  String?
  selectorHints Json?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  scrapeJobs    ScrapeJob[]

  @@index([isActive])
  @@index([sourceType])
}

model ScrapeJob {
  id              String       @id @default(cuid())
  scrapeSourceId  String
  status          String       @default("RUNNING")
  candidatesFound Int          @default(0)
  rawPayload      Json?
  errorMessage    String?
  startedAt       DateTime     @default(now())
  completedAt     DateTime?
  scrapeSource    ScrapeSource @relation(fields: [scrapeSourceId], references: [id], onDelete: Cascade)
  stagedExams     StagedExam[]

  @@index([scrapeSourceId])
  @@index([status])
  @@index([startedAt])
}

model StagedExam {
  id                    String                 @id @default(cuid())
  scrapeJobId           String
  existingExamId        String?
  title                 String
  shortTitle            String?
  slug                  String?
  description           String?
  conductingBody        String?
  category              String?
  status                String?                @default("NOTIFICATION")
  examLevel             String?
  state                 String?
  qualificationCriteria String?
  applicationFee        String?
  officialWebsite       String?
  notificationUrl       String?
  aiConfidence          Float?
  aiNotes               String?
  reviewStatus          String                 @default("PENDING")
  reviewNote            String?
  reviewedBy            String?
  reviewedAt            DateTime?
  deduplicationKey      String?
  contentHash           String?
  isDuplicate           Boolean                @default(false)
  duplicateOfStagedId   String?
  mergedSourceUrls      String[]
  sourceCount           Int                    @default(1)
  sourceUrl             String?
  scrapedAt             DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  totalVacancies        String?
  additionalDetails     String?
  salary                String?
  age                   String?
  examYear              Int?
  scrapeJob             ScrapeJob              @relation(fields: [scrapeJobId], references: [id], onDelete: Cascade)
  stagedEvents          StagedLifecycleEvent[]

  @@index([scrapeJobId])
  @@index([reviewStatus])
  @@index([existingExamId])
  @@index([category, reviewStatus])
  @@index([createdAt])
  @@index([deduplicationKey])
  @@index([contentHash])
  @@index([isDuplicate, reviewStatus])
  @@index([examYear])
}

model StagedLifecycleEvent {
  id           String     @id @default(cuid())
  stagedExamId String
  stage        String
  stageOrder   Int        @default(0)
  title        String
  description  String?
  startsAt     DateTime?
  endsAt       DateTime?
  isTBD        Boolean    @default(false)
  actionUrl    String?
  actionLabel  String?
  createdAt    DateTime   @default(now())
  stagedExam   StagedExam @relation(fields: [stagedExamId], references: [id], onDelete: Cascade)

  @@index([stagedExamId])
  @@index([stage])
}

model Exam {
  id                    String           @id @default(cuid())
  title                 String
  shortTitle            String
  slug                  String           @unique
  description           String?
  conductingBody        String
  applicationFee        String?
  officialWebsite       String?
  notificationUrl       String?
  createdBy             String
  isPublished           Boolean          @default(false)
  publishedAt           DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  category              String
  status                String           @default("NOTIFICATION")
  examLevel             String           @default("NATIONAL")
  qualificationCriteria String?
  state                 String?
  deduplicationKey      String?          @unique
  sourceStagedExamId    String?
  totalVacancies        String?
  additionalDetails     String?
  salary                String?
  age                   String?
  examYear              Int?
  isTrending            Boolean          @default(false)
  lifecycleEvents       LifecycleEvent[]
  seoPages              SeoPage[]

  @@index([category])
  @@index([examLevel])
  @@index([state])
  @@index([status])
  @@index([isPublished, status])
  @@index([conductingBody])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([isPublished, updatedAt, publishedAt])
  @@index([category, isPublished])
  @@index([isTrending])
  @@index([isPublished, isTrending])
  @@index([examYear])
}

model LifecycleEvent {
  id                  String            @id @default(cuid())
  examId              String
  title               String
  description         String?
  endsAt              DateTime?
  actionUrl           String?
  notificationSent    Boolean           @default(false)
  notifiedAt          DateTime?
  createdBy           String
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  actionLabel         String?
  isTBD               Boolean           @default(false)
  stage               String
  startsAt            DateTime?
  sourceStagedEventId String?
  stageOrder          Int               @default(0)
  examSlug            String?
  exam                Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  notifications       NotificationLog[]

  @@index([examId, stageOrder])
  @@index([examSlug, stage])
}

model PushToken {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  deviceModel String?
  appVersion  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  platform    String

  @@index([userId])
  @@index([isActive])
}

model NotificationLog {
  id               String         @id @default(cuid())
  lifecycleEventId String
  title            String
  body             String
  data             Json?
  targetTokens     Int            @default(0)
  successCount     Int            @default(0)
  failureCount     Int            @default(0)
  errorMessage     String?
  sentAt           DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  status           String         @default("PENDING")
  lifecycleEvent   LifecycleEvent @relation(fields: [lifecycleEventId], references: [id], onDelete: Cascade)

  @@index([lifecycleEventId])
  @@index([status])
  @@index([createdAt])
}

model User {
  id                   String    @id @default(cuid())
  name                 String
  phone                String    @unique
  state                String?
  city                 String?
  dateOfBirth          DateTime?
  gender               String?
  qualification        String?
  preferredCategories  String[]
  preferredExamLevel   String?
  savedExamIds         String[]
  employmentStatus     String?
  languagePreference   String    @default("HINDI")
  notificationsEnabled Boolean   @default(true)
  fcmToken             String?
  platform             String?
  appVersion           String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  degree               String?
  specialization       String?

  @@index([phone])
  @@index([state])
  @@index([qualification])
  @@index([degree])
  @@index([specialization])
  @@index([employmentStatus])
}

model AppConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
}

model HomeBanner {
  id          String    @id @default(cuid())
  imageUrl    String
  actionUrl   String?
  title       String?
  description String?
  priority    Int       @default(0)
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive, priority])
}

model SeoPage {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  metaTitle       String?
  metaDescription String?
  content         String
  keywords        String[] @default([])
  ogImage         String?
  canonicalUrl    String?
  isPublished     Boolean  @default(true)
  isTrending      Boolean  @default(false)
  category        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  examId          String?
  exam            Exam?    @relation(fields: [examId], references: [id])

  @@index([slug])
  @@index([isPublished])
  @@index([isTrending])
  @@index([category])
  @@index([examId])
  @@index([createdAt])
  @@index([category, isPublished])
  @@index([isPublished, isTrending])
}
