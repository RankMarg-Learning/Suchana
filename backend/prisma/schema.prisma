generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Exam — core entity representing a government exam cycle
model Exam {
  id                    String           @id @default(cuid())
  title                 String
  shortTitle            String
  slug                  String           @unique
  description           String?
  conductingBody        String
  category              String
  examLevel             String           @default("NATIONAL") // NATIONAL, STATE, OTHER
  state                 String?          // For STATE level exams (e.g. Maharashtra, Bihar)
  minAge                Int?
  maxAge                Int?
  qualificationCriteria Json?            // Structured qualification data
  totalVacancies        Int?
  applicationFee        Json?
  officialWebsite       String?
  notificationUrl       String?
  status                String           @default("UPCOMING")
  isPublished           Boolean          @default(false)
  publishedAt           DateTime?
  createdBy             String
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  lifecycleEvents       LifecycleEvent[]

  @@index([category])
  @@index([status])
  @@index([examLevel])
  @@index([conductingBody])
  @@index([isPublished, status])
}

/// LifecycleEvent - a milestone within an exam's lifecycle
model LifecycleEvent {
  id               String            @id @default(cuid())
  examId           String
  stage            String?           // e.g. PRELIMS, MAINS, TIER_1, PAPER_1
  eventType        String            // REGISTRATION, EXAM_DATE, RESULT, etc.
  title            String            // Display Title: "Apply Online", "Prelims Admit Card"
  description      String?
  startsAt         DateTime?         // Nullable if TBD
  endsAt           DateTime?         // For ranges like Registration window
  isTBD            Boolean           @default(false)
  isConfirmed      Boolean           @default(true)
  actionUrl        String?           // Deep link or external link
  actionLabel      String?           // Custom label: "Apply Now", "Check Result"
  notificationSent Boolean           @default(false)
  notifiedAt       DateTime?
  createdBy        String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  exam             Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  notifications    NotificationLog[]

  @@index([examId])
  @@index([eventType])
  @@index([startsAt])
  @@index([stage])
  @@index([notificationSent, startsAt])
}

/// Device push token — registered by mobile app
model PushToken {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  deviceModel String?
  appVersion  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  platform    String

  @@index([userId])
  @@index([isActive])
}

/// NotificationLog — audit trail for every push notification attempt
model NotificationLog {
  id               String         @id @default(cuid())
  lifecycleEventId String
  title            String
  body             String
  data             Json?
  targetTokens     Int            @default(0)
  successCount     Int            @default(0)
  failureCount     Int            @default(0)
  errorMessage     String?
  sentAt           DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  status           String         @default("PENDING")
  lifecycleEvent   LifecycleEvent @relation(fields: [lifecycleEventId], references: [id], onDelete: Cascade)

  @@index([lifecycleEventId])
  @@index([status])
  @@index([createdAt])
}

/// AdminAuditLog — tracks all admin mutations for compliance
model AdminAuditLog {
  id          String   @id @default(cuid())
  adminId     String
  action      String
  entityType  String
  entityId    String
  beforeState Json?
  afterState  Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([adminId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

/// User — mobile app user for personalized exam feed, targeting and notifications
/// Personalization fields power:
///   - Exam eligibility filtering (age, gender, qualification)
///   - Ad targeting demographics (age group, state, education, employment)
///   - Notification delivery (fcmToken, platform)
model User {
  id                  String   @id @default(cuid())
  name                String
  phone               String   @unique

  // ── Location & Demography (ad targeting + state-level exam filter) ──
  state               String?           // e.g. "Bihar", "Maharashtra"
  city                String?

  // ── Eligibility-based personalization ──────────────────────────────
  dateOfBirth         DateTime?         // For age-based exam filter (min/max age)
  gender              String?           // MALE | FEMALE | OTHER
  qualification       String?           // 10TH_PASS | 12TH_PASS | GRADUATE | POST_GRADUATE | PHD

  // ── Exam preferences ───────────────────────────────────────────────
  preferredCategories String[]          // ["UPSC", "SSC", "BANKING", ...]
  preferredExamLevel  String?           // NATIONAL | STATE | BOTH
  savedExamIds        String[]          // IDs of bookmarked exams

  // ── Occupation (ad targeting: student vs. working professional) ─────
  employmentStatus    String?           // STUDENT | EMPLOYED | UNEMPLOYED | OTHER

  // ── App preferences ────────────────────────────────────────────────
  languagePreference  String   @default("HINDI")  // HINDI | ENGLISH
  notificationsEnabled Boolean @default(true)

  // ── Push notification delivery ─────────────────────────────────────
  fcmToken            String?
  platform            String?           // android | ios | web
  appVersion          String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([phone])
  @@index([state])
  @@index([qualification])
  @@index([employmentStatus])
}
